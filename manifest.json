{
  "manifest_version": 3,
  "name": "CheckMate",
  "version": "1.5.0",
  "description": "Automatise le pointage de présence sur CESAR Emineo",
  "permissions": [
    "storage",
    "activeTab",
    "notifications",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://cesar.emineo-informatique.fr/*",
    "https://api.github.com/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["https://cesar.emineo-informatique.fr/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "CheckMate",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "checkmate@cesar.emineo",
      "strict_min_version": "142.0"
    }
  }
}
